# ─────────────────────────────────────────────────────────────
#  CakeCraft Platform — Environment variables
#  Copy this file to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# MySQL connection string.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/cakecraft"

# NextAuth — used to sign admin session cookies.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Default tenant slug to load when no subdomain is present (local dev).
DEFAULT_TENANT="sweet-bloom"

# ── Razorpay (test keys from dashboard.razorpay.com) ──
# These are platform-level fallbacks; each tenant can override
# its own keys from the Admin → Payments screen (stored in DB).
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Public base URL (used for absolute links / webhooks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
