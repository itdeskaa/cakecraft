# ─────────────────────────────────────────────────────────────
#  PRODUCTION env for Hostinger. Copy to ".env" ON THE SERVER and
#  fill with real values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# MySQL created in hPanel → Databases → MySQL Databases.
# Format: mysql://DBUSER:DBPASS@HOST:3306/DBNAME
# On Hostinger shared hosting HOST is usually "localhost".
DATABASE_URL="mysql://u123_cake:STRONGPASS@localhost:3306/u123_cakecraft"

# Long random secret:  generate with  openssl rand -base64 32
NEXTAUTH_SECRET="PUT-A-LONG-RANDOM-STRING-HERE"

# Your real domain WITH https (must match the live site exactly).
NEXTAUTH_URL="https://yourdomain.in"
NEXT_PUBLIC_APP_URL="https://yourdomain.in"

# Single-brand India site → which tenant to show on the main domain.
DEFAULT_TENANT="sweet-bloom"

# Razorpay LIVE keys can also be set per-store in Admin → Payments (recommended).
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Uploads on a persistent-disk host (Hostinger Node / VPS): leave EMPTY → saves to
# <project>/public/uploads. On Vercel/Netlify (no disk) use Cloudinary below instead.
UPLOAD_DIR=""

# ── Cloudinary (image uploads on hosts WITHOUT a persistent disk, e.g. Vercel) ──
# Free account at cloudinary.com. Create an UNSIGNED upload preset.
# When both are set, admin image uploads go to Cloudinary instead of local disk.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET=""
